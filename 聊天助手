from agents.qa_agent import QAAgent
from agents.doc_agent import DocAgent

class MainAgent:
    def __init__(self):
        self.qa_agent = QAAgent()
        self.doc_agent = DocAgent()

    def handle_task(self, task_type, content):
        if task_type == "qa":
            return self.qa_agent.run(content)
        elif task_type == "doc":
            return self.doc_agent.run(content)
        else:
            return "未知任务类型"
agents/qa_agent.py
from openai import OpenAI

class QAAgent:
    def __init__(self):
        self.client = OpenAI(api_key="YOUR_API_KEY")

    def run(self, question):
        response = self.client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": question}]
        )
        return response.choices[0].message.content
agents/doc_agent.py
from openai import OpenAI

class DocAgent:
    def __init__(self):
        self.client = OpenAI(api_key="YOUR_API_KEY")

    def run(self, prompt):
        response = self.client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": f"生成文档内容: {prompt}"}]
        )
        return response.choices[0].message.content
