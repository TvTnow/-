from agents.main_agent import MainAgent

def main():
    agent = MainAgent()
    print("多 Agent 聊天助手启动！输入 exit 退出")
    
    while True:
        user_input = input("你：")
        if user_input.lower() == "exit":
            break
        
        # 简单逻辑判断任务类型
        if user_input.lower().startswith("问:"):
            task_type = "qa"
            content = user_input[2:].strip()
        elif user_input.lower().startswith("写:"):
            task_type = "doc"
            content = user_input[2:].strip()
        else:
            task_type = "qa"
            content = user_input
        
        reply = agent.handle_task(task_type, content)
        print("Agent：", reply)

if __name__ == "__main__":
    main()
